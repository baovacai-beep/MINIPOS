<?xml version="1.0" encoding="utf-8" ?>
<configuration>
    <startup>
        <supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.7.2" />
    </startup>
    <connectionStrings>
        <!--
            Sửa Server=. thành tên SQL Server instance của bạn nếu cần.
            Ví dụ: Server=DESKTOP-ABC\SQLEXPRESS  hoặc  Server=localhost
        -->
        <add name="MiniPOS"
             connectionString="Server=.\SQLEXPRESS;Database=MiniPOS_DB;Integrated Security=True;"
             providerName="System.Data.SqlClient" />
    </connectionStrings>
</configuration>